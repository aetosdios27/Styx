{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Styx",
  "version": "0.1.0",
  "identifier": "dev.aetos.styx",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "./dist"
  },
  "app": {
    "windows": [
      {
        "title": "Styx",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
